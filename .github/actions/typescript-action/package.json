{
  "name": "typescript-action",
  "version": "1.0.0",
  "description": "Example TypeScript Actions",
  "type": "module",
  "scripts": {
    "update": "npm exec --yes -- npm-check-updates --upgrade --target greatest --pre 0 && npm install",
    "format": "prettier --write .",
    "lint": "run-p lint:*",
    "lint:prettier": "prettier --check .",
    "lint:eslint": "eslint .",
    "lint:tsc": "tsc --noEmit",
    "test": "jest",
    "build": "node build.js",
    "all": "run-s format lint test build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cions/actions-playground.git"
  },
  "author": "cions",
  "license": "MIT",
  "devDependencies": {
    "@actions/core": "^1.10.0",
    "@actions/github": "^5.1.1",
    "@jest/globals": "^29.6.4",
    "@types/node": "^20.5.7",
    "@typescript-eslint/eslint-plugin": "^6.5.0",
    "@typescript-eslint/parser": "^6.5.0",
    "@vercel/ncc": "^0.36.1",
    "eslint": "^8.48.0",
    "eslint-config-prettier": "^9.0.0",
    "jest": "^29.6.4",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.0.3",
    "ts-jest": "^29.1.1",
    "ts-jest-resolver": "^2.0.1",
    "typescript": "^5.2.2"
  }
}
