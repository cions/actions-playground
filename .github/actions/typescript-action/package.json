{
  "name": "typescript-action",
  "version": "1.0.0",
  "description": "Example TypeScript Actions",
  "homepage": "https://github.com/cions/actions-playground",
  "license": "MIT",
  "author": "cions",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cions/actions-playground.git"
  },
  "type": "module",
  "exports": {
    "./*": "./*"
  },
  "scripts": {
    "update": "npm exec --yes -- npm-check-updates --upgrade --target greatest --pre 0 --peer && npm audit fix && npm install",
    "fix": "eslint --fix",
    "lint": "run-p lint:*",
    "lint:eslint": "eslint",
    "lint:tsc": "tsc --noEmit",
    "test": "jest",
    "build": "node build.js",
    "all": "run-s lint test build"
  },
  "devDependencies": {
    "@actions/core": "^1.11.1",
    "@actions/github": "^6.0.0",
    "@jest/globals": "^29.7.0",
    "@stylistic/eslint-plugin": "^2.9.0",
    "@vercel/ncc": "^0.38.2",
    "eslint": "^9.12.0",
    "eslint-plugin-jest": "^28.8.3",
    "globals": "^15.11.0",
    "jest": "^29.7.0",
    "npm-run-all": "^4.1.5",
    "ts-jest": "^29.2.5",
    "ts-jest-resolver": "^2.0.1",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.9.0"
  }
}
